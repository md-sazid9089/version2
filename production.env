# ==========================================
# 1. FRONTEND ENVIRONMENT VARIABLES (Add to Vercel)
# ==========================================
# Set this in Vercel. Because the backend doesn't use an /api prefix, do NOT add /api to the end.
VITE_API_BASE_URL=https://version2-62fe.onrender.com

# ==========================================
# 2. BACKEND ENVIRONMENT VARIABLES (Add to Render/Azure Backend)
# ==========================================
# Replace with your actual Vercel deployed URL
CORS_ORIGINS=https://version2-flame.vercel.app,http://localhost:5173

# Replace with your actual ML deployed URL
ML_PREDICTION_URL=https://version2-1-vkzu.onrender.com/predict

# --- Database Variables (Azure SQL / MSSQL) ---
# Option A: Full connection string (use this on Render — paste as single env var)
DATABASE_URL=mssql+pyodbc://admin123:Sazidcse420@versionlol.database.windows.net/hackathon?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no&Connection+Timeout=30

# Option B: Individual vars (used as fallback if DATABASE_URL is not set)
DB_HOST=versionlol.database.windows.net
DB_PORT=1433
DB_USER=admin123
DB_PASSWORD=Sazidcse420
DB_NAME=hackathon
DB_SSL_MODE=disable

